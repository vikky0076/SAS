# Firebase Admin SDK Configuration
# You can choose either Option 1 (using the full JSON service account string)
# or Option 2 (using individual credentials fields).

# --- Option 1: Full Service Account JSON String ---
# To use this, go to Firebase Console > Project Settings > Service Accounts > Generate New Private Key.
# Convert the downloaded JSON file into a single line string.
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", "client_id": "...", "auth_uri": "...", "token_uri": "...", "auth_provider_x509_cert_url": "...", "client_x509_cert_url": "...", "universe_domain": "..."}'

# --- Option 2: Individual Service Account Fields ---
# If Option 1 is not used, you can define these three variables instead:
FIREBASE_PROJECT_ID=smart-attendance-system-83712
FIREBASE_CLIENT_EMAIL=your-service-account@smart-attendance-system-83712.iam.gserviceaccount.com
# For the private key, make sure to replace actual newlines with literal '\n' characters so it is single-line.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
